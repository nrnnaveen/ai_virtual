# ─────────────────────────────────────────────────────────────────
# Backend Environment Variables
# Copy this file to .env and fill in your actual API keys.
# ─────────────────────────────────────────────────────────────────

# Required – Anthropic Claude (LLM)
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# Required – Deepgram (Speech-to-Text)
# Get your key at https://console.deepgram.com/
DEEPGRAM_API_KEY=...your-key-here...

# Required – ElevenLabs (Text-to-Speech)
# Get your key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=...your-key-here...

# Optional – URL of this backend service (used for documentation / CORS hints)
# In production set this to your Render backend URL, e.g.:
#   BACKEND_URL=https://ai-virtual-backend.onrender.com
BACKEND_URL=http://localhost:8000

# Optional – Comma-separated list of allowed CORS origins.
# Defaults to localhost for local development.
# In production, add your frontend URL, e.g.:
#   ALLOWED_ORIGINS=https://ai-virtual-frontend.onrender.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
