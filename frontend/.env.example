# ─────────────────────────────────────────────────────────────────
# Frontend Environment Variables
# Copy this file to .env and fill in the values for your setup.
# ─────────────────────────────────────────────────────────────────

# Optional – WebSocket base URL for the backend.
# In development this is derived automatically from window.location.
# In production (Render / any host) set this to your backend WebSocket URL, e.g.:
#   VITE_WS_URL=wss://ai-virtual-backend.onrender.com/ws
VITE_WS_URL=

# Optional – HTTP base URL for the backend (used by the Vite dev proxy).
# Only relevant during local development (`npm run dev`).
# Defaults to http://localhost:8000
VITE_API_URL=http://localhost:8000
